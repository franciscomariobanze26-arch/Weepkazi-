rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             (
               (request.auth.token.email == "franciscomariobanze26@gmail.com" && request.auth.token.email_verified == true) ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
             );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
             request.resource.data.uid == resource.data.uid;
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, min, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= min && 
              request.resource.data[field].size() <= max);
    }

    function isRecent(field) {
      return request.resource.data[field] is timestamp &&
             request.resource.data[field] > request.time - duration.value(5, 'm') &&
             request.resource.data[field] <= request.time;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'role']) &&
             data.uid is string && (data.uid == request.auth.uid || isAdmin()) &&
             isValidString('displayName', 1, 100) &&
             data.role in ['client', 'provider', 'admin'] &&
             isValidOptionalString('handle', 3, 30) &&
             isValidOptionalString('bio', 0, 500);
    }

    function isValidService(data) {
      return hasRequiredFields(['title', 'category', 'authorId', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             data.category is string &&
             data.authorId is string && data.authorId == request.auth.uid &&
             isRecent('createdAt') &&
             isValidOptionalString('description', 0, 2000);
    }

    function isValidJob(data) {
      return hasRequiredFields(['title', 'description', 'company', 'location', 'type', 'authorId', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             isValidString('description', 1, 5000) &&
             isValidString('company', 1, 100) &&
             data.location is map &&
             data.type in ['full-time', 'part-time', 'internship', 'freelance'] &&
             data.authorId is string && data.authorId == request.auth.uid &&
             isRecent('createdAt');
    }

    function isValidMessage(data) {
      return hasRequiredFields(['senderId', 'content', 'createdAt']) &&
             data.senderId is string && data.senderId == request.auth.uid &&
             isValidString('content', 1, 5000) &&
             isRecent('createdAt');
    }

    function isValidChat(data) {
      return hasRequiredFields(['participants', 'lastMessage', 'lastMessageAt', 'status', 'initiatorId', 'createdAt']) &&
             data.participants is list && data.participants.size() == 2 && data.participants.hasAny([request.auth.uid]) &&
             isValidString('lastMessage', 0, 500) &&
             data.lastMessageAt is timestamp &&
             data.status in ['pending', 'active', 'rejected'] &&
             data.initiatorId is string &&
             isRecent('createdAt');
    }

    function isValidChatUpdate(data) {
      return (resource.data.participants.hasAny([request.auth.uid]) || isAdmin()) &&
             (!('participants' in data) || data.participants == resource.data.participants) &&
             (!('initiatorId' in data) || data.initiatorId == resource.data.initiatorId) &&
             (!('createdAt' in data) || data.createdAt == resource.data.createdAt) &&
             (!('unreadCount' in data) || data.unreadCount is map) &&
             (!('lastMessage' in data) || data.lastMessage is string) &&
             (!('lastMessageAt' in data) || data.lastMessageAt is timestamp) &&
             (!('status' in data) || data.status is string);
    }

    function isValidOrder(data) {
      return hasRequiredFields(['serviceId', 'clientId', 'providerId', 'status', 'createdAt']) &&
             data.serviceId is string &&
             data.clientId is string && data.clientId == request.auth.uid &&
             data.providerId is string &&
             data.status is string &&
             isRecent('createdAt');
    }

    function isValidReview(data) {
      return hasRequiredFields(['serviceId', 'authorId', 'rating', 'comment', 'createdAt']) &&
             data.serviceId is string &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             isValidString('comment', 1, 1000) &&
             isRecent('createdAt');
    }

    function isValidCommunity(data) {
      return hasRequiredFields(['name', 'description', 'creatorId', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             isValidString('description', 1, 2000) &&
             data.creatorId is string && data.creatorId == request.auth.uid &&
             isRecent('createdAt') &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 2000)) &&
             (!('memberCount' in data) || data.memberCount is number) &&
             (!('requiresApproval' in data) || data.requiresApproval is bool) &&
             (!('category' in data) || (data.category is string && data.category.size() < 50));
    }

    function isValidCommunityMember(data) {
      return hasRequiredFields(['uid', 'role', 'status', 'joinedAt']) &&
             data.uid is string &&
             data.role in ['admin', 'member'] &&
             data.status in ['pending', 'approved'] &&
             isRecent('joinedAt') &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string);
    }

    function isValidCommunityMessage(data) {
      return hasRequiredFields(['senderId', 'content', 'createdAt']) &&
             data.senderId is string && data.senderId == request.auth.uid &&
             isValidString('content', 1, 5000) &&
             isRecent('createdAt') &&
             (!('senderName' in data) || (data.senderName is string && data.senderName.size() < 100)) &&
             (!('senderPhoto' in data) || data.senderPhoto == null || (data.senderPhoto is string && data.senderPhoto.size() < 2000)) &&
             (!('imageURL' in data) || data.imageURL == null || (data.imageURL is string && data.imageURL.size() < 2000)) &&
             (!('audioURL' in data) || data.audioURL == null || (data.audioURL is string && data.audioURL.size() < 2000)) &&
             (!('type' in data) || data.type in ['text', 'audio', 'image']);
    }

    function isValidAnnouncement(data) {
      return hasRequiredFields(['content', 'authorId', 'createdAt']) &&
             isValidString('content', 1, 5000) &&
             data.authorId is string && data.authorId == request.auth.uid &&
             isRecent('createdAt');
    }

    function isValidReport(data) {
      return hasRequiredFields(['reportedId', 'reportedType', 'reporterId', 'status', 'createdAt']) &&
             data.reportedId is string &&
             data.reportedType in ['user', 'service', 'message', 'announcement'] &&
             data.reporterId is string && data.reporterId == request.auth.uid &&
             data.status in ['pending', 'in_review', 'resolved', 'rejected'] &&
             isRecent('createdAt');
    }

    function isValidFollow(data) {
      return hasRequiredFields(['followerId', 'followingId', 'createdAt']) &&
             data.followerId is string && data.followerId == request.auth.uid &&
             data.followingId is string &&
             isRecent('createdAt');
    }

    function isValidNotification(data) {
      return hasRequiredFields(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             isValidString('title', 1, 200) &&
             isValidString('message', 1, 1000) &&
             data.type in ['message', 'interest', 'review', 'promotion', 'system'] &&
             data.read is bool &&
             isRecent('createdAt');
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || 
                    isAdmin() || 
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'followingCount', 'online', 'lastSeen', 'unreadCount']));
      allow delete: if isAdmin();
    }

    match /users_private/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidService(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin()) && isValidService(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin()) && isValidJob(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource == null || isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && request.auth.uid in resource.data.participants));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants));
        allow create: if isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants));
        allow update: if isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants));
        allow delete: if isAdmin();
      }
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidAnnouncement(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidCommunity(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());

      match /members/{memberId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidCommunityMember(request.resource.data);
        allow update: if isAuthenticated() && (
          get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || 
          isAdmin() ||
          (isOwner(memberId) && request.resource.data.status == resource.data.status)
        );
        allow delete: if isAuthenticated() && (
          get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || 
          isAdmin() || 
          isOwner(memberId)
        );
      }

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                      exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.status == 'approved' &&
                      isValidCommunityMessage(request.resource.data);
        allow delete: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid || 
          get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid || 
          isAdmin()
        );
      }
    }

    match /education/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && (request.resource.data.followerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.followerId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
